{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "timezone": "Etc/UTC",
  "schedule": [
    "before 6am on monday"
  ],
  "branchPrefix": "renovate/",
  "automerge": false,
  "enabledManagers": [
    "gomod",
    "github-actions"
  ],
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Group low-risk Go patch and minor updates; Dependabot is the default PR source, Renovate requires dashboard approval to avoid duplicate PRs.",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "go minor and patch dependencies",
      "dependencyDashboardApproval": true
    },
    {
      "description": "Group low-risk GitHub Actions patch and minor updates; Dependabot is the default PR source, Renovate requires dashboard approval to avoid duplicate PRs.",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "github actions minor and patch updates",
      "dependencyDashboardApproval": true
    },
    {
      "description": "Major updates require explicit dashboard approval.",
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true,
      "addLabels": [
        "major"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "dependencies"
    ],
    "prCreation": "immediate"
  }
}
